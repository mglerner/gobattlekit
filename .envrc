# direnv: auto-activate the uv-managed test venv when you enter this dir
# (shell + Emacs/eglot). This venv is just the pytest harness; actual app
# dev/builds go through `briefcase dev` (BeeWare manages its own env).
# Run `direnv allow` once to trust this file.
export VIRTUAL_ENV="$PWD/.venv"
PATH_add "$VIRTUAL_ENV/bin"
